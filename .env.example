# ---------------------------------------------------------------------------
# Organica Living — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ---------------------------------------------------------------------------

# Public site URL (used for redirects, emails, Stripe return URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — keep secret, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (Developers -> API keys / Webhooks) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` locally, or the dashboard webhook signing secret in prod.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxx
